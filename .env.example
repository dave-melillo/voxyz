# VoxYZ Environment Configuration
# Copy to .env and fill in your values

# Server
PORT=3737

# STT — Deepgram (https://deepgram.com)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# TTS — ElevenLabs (https://elevenlabs.io)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# LLM — Anthropic (for intent classification)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# TTS Feature Toggle
# Set to "false" to disable TTS and run in text-only mode (no ElevenLabs calls)
TTS_ENABLED=true

# Agent Voice IDs (ElevenLabs)
# Defaults are placeholders — replace with real voice IDs from your ElevenLabs account
VOICE_GAMBIT=TxGEqnHWrfWFTfGW9XjX
VOICE_BEAST=pNInz6obpgDQGcFmaJgB
VOICE_WOLVERINE=EXAVITQu4vr4xnSDxMaL
VOICE_MAGNETO=VR6AewLTigWG4xSOukaG
VOICE_DAZZLER=jsCqWAovK2LkecY7zXl4
VOICE_NIGHTCRAWLER=onwK4e9ZLuTAKqWW03F9
VOICE_DEFAULT=pNInz6obpgDQGcFmaJgB
